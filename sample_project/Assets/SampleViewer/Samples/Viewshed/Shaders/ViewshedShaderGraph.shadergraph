        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "IsOccluded",
    "m_FunctionSource": "",
    "m_FunctionBody": "#if SHADERPASS == SHADERPASS_SHADOWS\n/* \nJust check if it's inside the IM area. Depth comparation not necessary,\navoid depth reprojection and artifacts \n*/\noccluded = occlusionSampleDepth > 0;\n#else\noccluded = occlusionSampleDepth > depth;\n#endif"
}

